import { useState, useEffect, useRef } from "react";

const SHOPS = [
  {
    id: "instant",
    name: "Instant Gaming",
    url: "https://www.instant-gaming.com/de/recherche/?q=",
    color: "#ff2d6b",
    glow: "#ff2d6b",
    icon: "⚡",
    tag: "GÜNSTIGSTE PREISE",
  },
  {
    id: "eneba",
    name: "Eneba",
    url: "https://www.eneba.com/de/?search=",
    color: "#00f0ff",
    glow: "#00f0ff",
    icon: "🎮",
    tag: "GLOBALER MARKT",
  },
  {
    id: "mmoga",
    name: "MMOGA",
    url: "https://www.mmoga.de/Games/?search=",
    color: "#b8ff00",
    glow: "#b8ff00",
    icon: "🔑",
    tag: "SOFORT KEYS",
  },
];

const POPULAR = [
  "Cyberpunk 2077", "Elden Ring", "GTA 6", "Red Dead Redemption 2",
  "The Witcher 3", "Hogwarts Legacy", "EA FC 25", "Call of Duty",
];

const glitch = `
@keyframes glitch {
  0% { transform: translate(0); }
  20% { transform: translate(-2px, 2px); clip-path: polygon(0 30%, 100% 30%, 100% 50%, 0 50%); }
  40% { transform: translate(2px, -2px); clip-path: polygon(0 60%, 100% 60%, 100% 80%, 0 80%); }
  60% { transform: translate(-1px, 1px); clip-path: polygon(0 10%, 100% 10%, 100% 30%, 0 30%); }
  80% { transform: translate(1px, -1px); }
  100% { transform: translate(0); }
}
@keyframes scanline {
  0% { transform: translateY(-100%); }
  100% { transform: translateY(100vh); }
}
@keyframes flicker {
  0%, 97%, 100% { opacity: 1; }
  98% { opacity: 0.4; }
  99% { opacity: 0.8; }
}
@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 20px #ff2d6b55, 0 0 40px #ff2d6b22; }
  50% { box-shadow: 0 0 35px #ff2d6baa, 0 0 70px #ff2d6b44; }
}
@keyframes neon-border {
  0%, 100% { border-color: #ff2d6b; box-shadow: 0 0 15px #ff2d6b88; }
  33% { border-color: #00f0ff; box-shadow: 0 0 15px #00f0ff88; }
  66% { border-color: #b8ff00; box-shadow: 0 0 15px #b8ff0088; }
}
@keyframes float-up {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes spin-slow {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}
@keyframes blink-cursor {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}
@keyframes grid-move {
  0% { background-position: 0 0; }
  100% { background-position: 40px 40px; }
}
`;

export default function GameSearchRadar() {
  const [query, setQuery] = useState("");
  const [searched, setSearched] = useState("");
  const [typed, setTyped] = useState("");
  const [time, setTime] = useState("");
  const [glitching, setGlitching] = useState(false);
  const [aiResult, setAiResult] = useState(null);
  const [aiLoading, setAiLoading] = useState(false);
  const inputRef = useRef(null);

  // Clock
  useEffect(() => {
    const tick = () => {
      const now = new Date();
      setTime(now.toLocaleTimeString("de-DE", { hour12: false }));
    };
    tick();
    const t = setInterval(tick, 1000);
    return () => clearInterval(t);
  }, []);

  // Typewriter effect for placeholder
  useEffect(() => {
    const words = ["Cyberpunk 2077", "Elden Ring", "GTA VI", "Fortnite", "Baldur's Gate 3"];
    let wi = 0, ci = 0, deleting = false;
    const t = setInterval(() => {
      const word = words[wi];
      if (!deleting) {
        setTyped(word.slice(0, ci + 1));
        ci++;
        if (ci === word.length) { deleting = true; setTimeout(() => {}, 1200); }
      } else {
        setTyped(word.slice(0, ci - 1));
        ci--;
        if (ci === 0) { deleting = false; wi = (wi + 1) % words.length; }
      }
    }, deleting ? 60 : 90);
    return () => clearInterval(t);
  }, []);

  // Random glitch
  useEffect(() => {
    const t = setInterval(() => {
      setGlitching(true);
      setTimeout(() => setGlitching(false), 300);
    }, 8000);
    return () => clearInterval(t);
  }, []);

  const handleSearch = async (q) => {
    const searchQ = q || query;
    if (!searchQ.trim()) return;
    setSearched(searchQ.trim());
    setAiResult(null);
    setAiLoading(true);

    try {
      const res = await fetch("https://api.anthropic.com/v1/messages", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          model: "claude-sonnet-4-20250514",
          max_tokens: 1000,
          messages: [{
            role: "user",
            content: `Du bist ein Gaming-Experte. Gib mir kurze, prägnante Infos zum Spiel: "${searchQ}".
Antworte NUR in diesem JSON-Format (kein Markdown, keine Backticks):
{
  "title": "offizieller Spieltitel",
  "genre": "Genre (kurz, 2-3 Wörter)",
  "rating": "Metacritic-Score oder 'k.A.'",
  "year": "Erscheinungsjahr",
  "developer": "Entwickler",
  "description": "1-2 packende Sätze auf Deutsch",
  "tip": "1 kurzer Kauftipp auf Deutsch",
  "found": true oder false
}`
          }]
        })
      });
      const data = await res.json();
      const text = data.content?.map(i => i.text || "").join("") || "";
      const cleaned = text.replace(/```json|```/g, "").trim();
      const parsed = JSON.parse(cleaned);
      setAiResult(parsed);
    } catch {
      setAiResult({ found: false });
    }
    setAiLoading(false);
  };

  const handleKey = (e) => {
    if (e.key === "Enter") handleSearch();
  };

  return (
    <>
      <style>{glitch}</style>
      <div style={{
        minHeight: "100vh",
        background: "#050510",
        color: "#e0e0ff",
        fontFamily: "'Courier New', monospace",
        overflow: "hidden",
        position: "relative",
      }}>

        {/* Animated Grid Background */}
        <div style={{
          position: "fixed", inset: 0, zIndex: 0,
          backgroundImage: `
            linear-gradient(rgba(0,240,255,0.04) 1px, transparent 1px),
            linear-gradient(90deg, rgba(0,240,255,0.04) 1px, transparent 1px)
          `,
          backgroundSize: "40px 40px",
          animation: "grid-move 4s linear infinite",
          pointerEvents: "none",
        }} />

        {/* Scanline effect */}
        <div style={{
          position: "fixed", inset: 0, zIndex: 1, pointerEvents: "none",
          background: "repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,0.08) 2px, rgba(0,0,0,0.08) 4px)",
        }} />

        {/* Scanline sweep */}
        <div style={{
          position: "fixed", top: 0, left: 0, right: 0, height: "3px", zIndex: 2,
          background: "linear-gradient(transparent, rgba(0,240,255,0.3), transparent)",
          animation: "scanline 6s linear infinite",
          pointerEvents: "none",
        }} />

        {/* Corner decorations */}
        {[
          { top: 16, left: 16, borderTop: "2px solid #ff2d6b", borderLeft: "2px solid #ff2d6b" },
          { top: 16, right: 16, borderTop: "2px solid #00f0ff", borderRight: "2px solid #00f0ff" },
          { bottom: 16, left: 16, borderBottom: "2px solid #b8ff00", borderLeft: "2px solid #b8ff00" },
          { bottom: 16, right: 16, borderBottom: "2px solid #ff2d6b", borderRight: "2px solid #ff2d6b" },
        ].map((s, i) => (
          <div key={i} style={{ position: "fixed", width: 40, height: 40, zIndex: 10, ...s }} />
        ))}

        {/* Top HUD bar */}
        <div style={{
          position: "fixed", top: 0, left: 0, right: 0, height: 48, zIndex: 10,
          background: "rgba(5,5,16,0.95)",
          borderBottom: "1px solid rgba(0,240,255,0.2)",
          display: "flex", alignItems: "center", justifyContent: "space-between",
          padding: "0 24px",
        }}>
          <div style={{ display: "flex", gap: 20, fontSize: 10, color: "#00f0ff88", letterSpacing: 3 }}>
            <span>SYS.ONLINE</span>
            <span style={{ color: "#b8ff00" }}>▶ SEARCH.EXE</span>
          </div>
          <div style={{ fontSize: 11, color: "#ff2d6b", letterSpacing: 4, animation: "flicker 5s infinite" }}>
            {time}
          </div>
          <div style={{ display: "flex", gap: 16, fontSize: 10, color: "#00f0ff88", letterSpacing: 2 }}>
            {SHOPS.map(s => (
              <span key={s.id} style={{ color: s.color }}>● {s.name.toUpperCase()}</span>
            ))}
          </div>
        </div>

        {/* Main content */}
        <div style={{
          position: "relative", zIndex: 5,
          maxWidth: 900, margin: "0 auto",
          padding: "80px 24px 60px",
        }}>

          {/* Logo */}
          <div style={{ textAlign: "center", marginBottom: 48 }}>
            <div style={{
              fontSize: 11, letterSpacing: 8, color: "#00f0ff88",
              marginBottom: 8, animation: "float-up 0.8s ease both",
            }}>
              ◈ NEURAL NETWORK INITIALIZED ◈
            </div>

            <h1 style={{
              fontSize: "clamp(36px, 8vw, 72px)",
              fontWeight: 900,
              letterSpacing: -2,
              margin: 0,
              lineHeight: 1,
              animation: glitching ? "glitch 0.3s steps(2) both" : "float-up 1s ease both 0.1s",
              position: "relative",
            }}>
              <span style={{
                background: "linear-gradient(135deg, #ff2d6b, #00f0ff, #b8ff00)",
                WebkitBackgroundClip: "text",
                WebkitTextFillColor: "transparent",
                backgroundClip: "text",
                filter: "drop-shadow(0 0 30px #ff2d6b66)",
                fontFamily: "'Courier New', monospace",
                display: "block",
              }}>
                GAME_SEARCH
              </span>
              <span style={{
                fontSize: "clamp(10px, 2vw, 14px)",
                letterSpacing: 12,
                background: "linear-gradient(90deg, #ff2d6b88, #00f0ff88)",
                WebkitBackgroundClip: "text",
                WebkitTextFillColor: "transparent",
                backgroundClip: "text",
                display: "block",
                marginTop: 4,
                fontWeight: 400,
              }}>
                ◀ RADAR v2.0 ▶
              </span>
            </h1>

            <p style={{
              fontSize: 12, color: "#e0e0ff44", letterSpacing: 4,
              marginTop: 16, animation: "float-up 1s ease both 0.3s",
            }}>
              DURCHSUCHE 3 SHOPS — FINDE DEN BESTEN PREIS
            </p>
          </div>

          {/* Search Input */}
          <div style={{
            position: "relative", marginBottom: 32,
            animation: "float-up 1s ease both 0.4s",
          }}>
            <div style={{
              position: "relative",
              border: "1px solid #ff2d6b66",
              borderRadius: 4,
              overflow: "hidden",
              animation: "neon-border 6s linear infinite",
              boxShadow: "0 0 30px #ff2d6b22, inset 0 0 30px rgba(5,5,16,0.9)",
            }}>
              {/* Input prefix */}
              <div style={{
                position: "absolute", left: 20, top: "50%", transform: "translateY(-50%)",
                color: "#00f0ff", fontSize: 16, fontWeight: 700, zIndex: 2,
                letterSpacing: 2, userSelect: "none",
              }}>
                &gt;_
              </div>

              <input
                ref={inputRef}
                value={query}
                onChange={e => setQuery(e.target.value)}
                onKeyDown={handleKey}
                placeholder={typed || "Spiel suchen..."}
                style={{
                  width: "100%",
                  padding: "22px 160px 22px 60px",
                  background: "rgba(5,5,16,0.95)",
                  border: "none",
                  outline: "none",
                  color: "#e0e0ff",
                  fontSize: 18,
                  fontFamily: "'Courier New', monospace",
                  letterSpacing: 2,
                  caretColor: "#ff2d6b",
                  boxSizing: "border-box",
                }}
              />

              <button
                onClick={() => handleSearch()}
                style={{
                  position: "absolute", right: 8, top: "50%", transform: "translateY(-50%)",
                  padding: "10px 24px",
                  background: "linear-gradient(135deg, #ff2d6b, #c0004d)",
                  border: "none",
                  borderRadius: 3,
                  color: "#fff",
                  fontSize: 12,
                  fontWeight: 700,
                  letterSpacing: 3,
                  cursor: "pointer",
                  fontFamily: "'Courier New', monospace",
                  boxShadow: "0 0 20px #ff2d6b66",
                  transition: "all 0.2s",
                }}
                onMouseOver={e => e.target.style.boxShadow = "0 0 35px #ff2d6baa"}
                onMouseOut={e => e.target.style.boxShadow = "0 0 20px #ff2d6b66"}
              >
                SCAN ▶
              </button>
            </div>
          </div>

          {/* Popular searches */}
          {!searched && (
            <div style={{
              display: "flex", flexWrap: "wrap", gap: 8, justifyContent: "center",
              marginBottom: 48, animation: "float-up 1s ease both 0.6s",
            }}>
              <span style={{ fontSize: 10, color: "#e0e0ff33", letterSpacing: 3, alignSelf: "center" }}>
                TRENDING:
              </span>
              {POPULAR.map((g, i) => (
                <button
                  key={g}
                  onClick={() => { setQuery(g); handleSearch(g); }}
                  style={{
                    padding: "6px 14px",
                    background: "transparent",
                    border: `1px solid ${["#ff2d6b44", "#00f0ff44", "#b8ff0044"][i % 3]}`,
                    borderRadius: 2,
                    color: ["#ff2d6b88", "#00f0ff88", "#b8ff0088"][i % 3],
                    fontSize: 10,
                    letterSpacing: 2,
                    cursor: "pointer",
                    fontFamily: "'Courier New', monospace",
                    transition: "all 0.2s",
                  }}
                  onMouseOver={e => {
                    e.target.style.background = ["rgba(255,45,107,0.1)", "rgba(0,240,255,0.1)", "rgba(184,255,0,0.1)"][i % 3];
                    e.target.style.color = ["#ff2d6b", "#00f0ff", "#b8ff00"][i % 3];
                  }}
                  onMouseOut={e => {
                    e.target.style.background = "transparent";
                    e.target.style.color = ["#ff2d6b88", "#00f0ff88", "#b8ff0088"][i % 3];
                  }}
                >
                  {g}
                </button>
              ))}
            </div>
          )}

          {/* AI Info Card */}
          {searched && (
            <div style={{ marginBottom: 32 }}>
              {aiLoading ? (
                <div style={{
                  padding: 24,
                  border: "1px solid #00f0ff33",
                  borderRadius: 4,
                  background: "rgba(0,240,255,0.03)",
                  textAlign: "center",
                  color: "#00f0ff88",
                  fontSize: 12,
                  letterSpacing: 4,
                  animation: "flicker 1s infinite",
                }}>
                  ◈ KI ANALYSIERT SPIELDATEN... ◈
                </div>
              ) : aiResult?.found ? (
                <div style={{
                  padding: 24,
                  border: "1px solid #00f0ff44",
                  borderRadius: 4,
                  background: "rgba(0,240,255,0.04)",
                  position: "relative",
                  overflow: "hidden",
                  animation: "float-up 0.5s ease both",
                }}>
                  {/* Accent line */}
                  <div style={{
                    position: "absolute", top: 0, left: 0, right: 0, height: 2,
                    background: "linear-gradient(90deg, transparent, #00f0ff, transparent)",
                  }} />

                  <div style={{ display: "flex", justifyContent: "space-between", flexWrap: "wrap", gap: 12 }}>
                    <div style={{ flex: 1, minWidth: 200 }}>
                      <div style={{ fontSize: 9, color: "#00f0ff88", letterSpacing: 4, marginBottom: 6 }}>
                        ◈ KI-SPIELANALYSE
                      </div>
                      <div style={{
                        fontSize: 22, fontWeight: 900,
                        color: "#e0e0ff",
                        textShadow: "0 0 20px #00f0ff44",
                        marginBottom: 8,
                      }}>
                        {aiResult.title}
                      </div>
                      <p style={{ fontSize: 12, color: "#e0e0ff88", lineHeight: 1.7, margin: "0 0 12px" }}>
                        {aiResult.description}
                      </p>
                      <div style={{
                        fontSize: 11, color: "#b8ff00",
                        border: "1px solid #b8ff0033",
                        display: "inline-block", padding: "4px 12px", borderRadius: 2,
                      }}>
                        💡 {aiResult.tip}
                      </div>
                    </div>

                    <div style={{ display: "flex", flexDirection: "column", gap: 10, minWidth: 140 }}>
                      {[
                        { label: "GENRE", val: aiResult.genre, c: "#ff2d6b" },
                        { label: "JAHR", val: aiResult.year, c: "#00f0ff" },
                        { label: "DEVELOPER", val: aiResult.developer, c: "#b8ff00" },
                        { label: "SCORE", val: aiResult.rating, c: "#ff2d6b" },
                      ].map(({ label, val, c }) => (
                        <div key={label} style={{
                          padding: "8px 12px",
                          background: `${c}0d`,
                          border: `1px solid ${c}33`,
                          borderRadius: 3,
                        }}>
                          <div style={{ fontSize: 8, color: `${c}88`, letterSpacing: 3 }}>{label}</div>
                          <div style={{ fontSize: 13, color: c, fontWeight: 700, marginTop: 2 }}>{val}</div>
                        </div>
                      ))}
                    </div>
                  </div>
                </div>
              ) : null}
            </div>
          )}

          {/* Shop Cards */}
          {searched && (
            <div>
              <div style={{
                fontSize: 10, color: "#e0e0ff33", letterSpacing: 6,
                textAlign: "center", marginBottom: 24,
              }}>
                ── JETZT IN 3 SHOPS SUCHEN ──
              </div>

              <div style={{ display: "grid", gridTemplateColumns: "repeat(auto-fit, minmax(260px, 1fr))", gap: 16 }}>
                {SHOPS.map((shop, i) => (
                  <a
                    key={shop.id}
                    href={shop.url + encodeURIComponent(searched)}
                    target="_blank"
                    rel="noopener noreferrer"
                    style={{
                      display: "block",
                      textDecoration: "none",
                      padding: 24,
                      border: `1px solid ${shop.color}44`,
                      borderRadius: 4,
                      background: `${shop.color}08`,
                      position: "relative",
                      overflow: "hidden",
                      cursor: "pointer",
                      transition: "all 0.3s",
                      animation: `float-up 0.6s ease both ${0.1 * i + 0.1}s`,
                    }}
                    onMouseOver={e => {
                      e.currentTarget.style.background = `${shop.color}18`;
                      e.currentTarget.style.borderColor = shop.color;
                      e.currentTarget.style.boxShadow = `0 0 40px ${shop.color}33, inset 0 0 40px ${shop.color}08`;
                      e.currentTarget.style.transform = "translateY(-3px)";
                    }}
                    onMouseOut={e => {
                      e.currentTarget.style.background = `${shop.color}08`;
                      e.currentTarget.style.borderColor = `${shop.color}44`;
                 
